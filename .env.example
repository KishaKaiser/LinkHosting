# ──────────────────────────────────────────────────────────
# LinkHosting environment configuration
# Copy to .env and fill in values before running docker compose
# ──────────────────────────────────────────────────────────

# ── Control-plane DB ──────────────────────────────────────
DB_NAME=linkhosting
DB_USER=linkhosting
DB_PASSWORD=change-me-strong-password

# ── Site databases (shared PostgreSQL) ───────────────────
SITE_DB_USER=postgres
SITE_DB_PASSWORD=change-me-strong-password-2

# ── Admin API ────────────────────────────────────────────
ADMIN_SECRET_KEY=change-me-to-random-64-char-string

# ── Networking ───────────────────────────────────────────
# Internal domain suffix (use .internal or .lan; avoid .local due to mDNS/Bonjour conflicts)
# NOTE: .local conflicts with mDNS/Bonjour on many networks and may cause DNS resolution issues.
# Using .internal or .lan is strongly recommended.
DOMAIN_SUFFIX=internal

# Port on which the control-plane API is exposed on the host
# Default: localhost only — change to 0.0.0.0:8000 to expose on LAN
CONTROL_PLANE_PORT=127.0.0.1:8000

# SFTP server host port
SFTP_PORT=2222

# ── Development mode ──────────────────────────────────────
# Set to true to skip real Docker/system calls (for local dev)
DEV_MODE=false
