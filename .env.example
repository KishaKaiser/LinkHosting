# ──────────────────────────────────────────────────────────
# LinkHosting environment configuration
# Copy to .env and fill in values before running docker compose
# ──────────────────────────────────────────────────────────

# ── Control-plane DB ──────────────────────────────────────
DB_NAME=linkhosting
DB_USER=linkhosting
DB_PASSWORD=change-me-strong-password

# ── Site databases (shared PostgreSQL) ───────────────────
SITE_DB_USER=postgres
SITE_DB_PASSWORD=change-me-strong-password-2

# ── Admin API ────────────────────────────────────────────
ADMIN_SECRET_KEY=change-me-to-random-64-char-string

# ── Networking ───────────────────────────────────────────
# Internal domain suffix — sites are reachable as <name>.<suffix>
# e.g. DOMAIN_SUFFIX=link  →  mysite.link
DOMAIN_SUFFIX=link

# Port on which the control-plane API is exposed on the host
# Bound to the fixed internal IP 192.168.4.32
CONTROL_PLANE_PORT=192.168.4.32:8000

# SFTP server host port
SFTP_PORT=2222

# ── Development mode ──────────────────────────────────────
# Set to true to skip real Docker/system calls (for local dev)
DEV_MODE=false
