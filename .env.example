# ──────────────────────────────────────────────────────────
# LinkHosting environment configuration
# Copy to .env and fill in values before running docker compose
# ──────────────────────────────────────────────────────────

# ── Control-plane DB ──────────────────────────────────────
DB_NAME=linkhosting
DB_USER=linkhosting
DB_PASSWORD=change-me-strong-password

# ── Site databases (shared PostgreSQL) ───────────────────
SITE_DB_USER=postgres
SITE_DB_PASSWORD=change-me-strong-password-2

# ── Admin API + Web Panel ────────────────────────────────
# Used for Bearer token auth (API) and the web panel login password
ADMIN_SECRET_KEY=change-me-to-random-64-char-string
# Used to sign session cookies for the web panel
SESSION_SECRET_KEY=change-me-to-another-random-64-char-string

# ── Networking ───────────────────────────────────────────
# Internal domain suffix — sites are reachable as <name>.<suffix>
# e.g. DOMAIN_SUFFIX=link  →  mysite.link
DOMAIN_SUFFIX=link

# Port on which the control panel is exposed on the host
PANEL_PORT=0.0.0.0:8000

# SFTP server host port
SFTP_PORT=2222

# ── Development mode ──────────────────────────────────────
# Set to true to skip real Docker/system calls (for local dev)
DEV_MODE=false

# ── Internal DNS (CoreDNS) ────────────────────────────────
# Set to false to disable the built-in CoreDNS service and skip automatic
# DNS record management (e.g. if you manage DNS externally).
DNS_ENABLED=true

# LAN IP of this server — the A record target for all site domains.
# Clients must use this server as their DNS resolver to resolve *.link names.
# Replace with your server's actual LAN IP.
HOST_LAN_IP=192.168.4.32

# Optional: bind address for the CoreDNS listener.
# Defaults to 0.0.0.0 (all interfaces). Restrict to a specific LAN IP if desired.
# DNS_LISTEN_ADDR=192.168.4.32

# Optional: host port the CoreDNS listener is exposed on.
# Defaults to 5353 to avoid conflicts with systemd-resolved on port 53.
# Set to 53 if you want the standard DNS port (requires disabling systemd-resolved first).
# DNS_PORT=5353

# ── Port-53 DNS forwarder (optional) ─────────────────────────────────────
# The built-in CoreDNS service listens on host port 5353 by default.
# Standard DNS clients (routers, devices) expect port 53, so you have two options:
#
# Option A — enable the dns-forwarder sidecar container:
#   This adds a second CoreDNS that listens on host port 53 and forwards
#   all queries to the main lh-dns container.  No changes to the host are needed.
#
#     docker compose --profile dns-forwarder up -d
#
#   Then point your router's DHCP DNS to this server's LAN IP (e.g. 192.168.4.32).
#   Verify: dig mysite.link @192.168.4.32
#
# Option B — move CoreDNS itself to port 53:
#   Disable systemd-resolved on the host, then set DNS_PORT=53 here and restart.
#
#     sudo systemctl disable --now systemd-resolved
#     sudo rm /etc/resolv.conf && echo "nameserver 1.1.1.1" | sudo tee /etc/resolv.conf
#     # Then set DNS_PORT=53 and run: docker compose up -d
#
# Without either option, query on port 5353 directly:
#   dig mysite.link @192.168.4.32 -p 5353
